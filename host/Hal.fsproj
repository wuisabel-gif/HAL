<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Hal</AssemblyName>
    <RootNamespace>Hal</RootNamespace>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <!-- Native Extism runtime (libextism) + the managed SDK. -->
    <PackageReference Include="Extism.runtime.all" Version="1.13.0" />
    <PackageReference Include="Extism.Sdk" Version="1.10.0" />
  </ItemGroup>

</Project>
